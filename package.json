{
  "name": "tsmap",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "predev": "node scripts/check-wmap-update.js",
    "prebuild": "node scripts/check-wmap-update.js",
    "dev": "vite",
    "dev:web": "vite --port 5301",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build",
    "build:site": "npm run build:web && ${ZENSICAL:-/home/paul/projects/wmap/.venv/bin/zensical} build --clean && cp -r dist site/app",
    "check": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "env -u GTK_PATH -u GTK_EXE_PREFIX -u GDK_PIXBUF_MODULE_FILE -u GDK_PIXBUF_MODULEDIR -u GIO_MODULE_DIR -u GTK_IM_MODULE_FILE -u LOCPATH tauri",
    "install-bin": "ln -sf $PWD/src-tauri/target/release/tsmap ~/.local/bin/tsmap"
  },
  "dependencies": {
    "@paulrobins/testdata-parser": "file:packages/parsers/pkg",
    "@paulrobins/wafermap": "^0.13.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "playwright": "^1.60.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
